# Transport: http (default — same as Web/SmcServerView.js on :8082)
VITE_TRANSPORT=http
# HTTP: leave empty for Vite proxy in dev; same-origin when deployed on :8082
VITE_HTTP_URL=
VITE_WS_URL=ws://localhost:8083
VITE_WATCHIO_NAME=SmcControl1
# Set true to force console debug logs in production builds
VITE_WATCHIO_DEBUG=false
