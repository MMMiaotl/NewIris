# Transport: smcServer (default) | watchIoHttp | watchIoWs
VITE_TRANSPORT=smcServer
# HTTP gateway host (HttpWebServer)
VITE_HOST_ADDRESS=localhost:8082
# HTTP base URL — leave empty for Vite proxy in dev
VITE_HTTP_URL=
# WebSocket URL for watchIoWs transport
VITE_WS_URL=ws://localhost:8083
VITE_WATCHIO_NAME=SmcControl1
# Set true to force console debug logs in production builds
VITE_WATCHIO_DEBUG=false
